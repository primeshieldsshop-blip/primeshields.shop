{
  "name": "prime-shields",
  "version": "1.0.0",
  "description": "Premium awards and trophies website for Prime Shields",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/styles.min.css --minify",
    "start": "serve . -l 3000",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/styles.min.css --watch"
  },
  "devDependencies": {
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.17"
  }
}